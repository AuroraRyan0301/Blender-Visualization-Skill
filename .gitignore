__pycache__/
*.pyc
*.pyo
.DS_Store
.idea/
.vscode/

# Bundled Blender from install.sh
blender/
.blender_dl/

# Local HDRIs are not tracked except the bundled default. See envmaps/README.md.
envmaps/*.exr
envmaps/*.hdr
!envmaps/studio.exr

# Render output and smoke artifacts
*.png
*.jpg
*.jpeg
*.gif
*.mp4
out/
output/
outputs/
_dummy_*

# Allow doc/example screenshots if added later under docs/ or examples/
!docs/**/*.png
!examples/**/*.png
